{
    "version": "1.0.0",
    "description": "Project infrastructure setup utility",
    "homepage": "https://github.com/MiguelRodo/infra",
    "license": "MIT",
    "url": "https://github.com/MiguelRodo/infra/archive/refs/tags/v1.0.0.zip",
    "hash": "REPLACE_WITH_ACTUAL_HASH",
    "extract_dir": "infra-1.0.0",
    "bin": "bin\\infra.ps1",
    "depends": [
        "git",
        "jq"
    ],
    "checkver": {
        "github": "https://github.com/MiguelRodo/infra"
    },
    "autoupdate": {
        "url": "https://github.com/MiguelRodo/infra/archive/refs/tags/v$version.zip",
        "extract_dir": "infra-$version"
    },
    "notes": [
        "Run 'infra --help' to get started.",
        "Make sure you have Git for Windows installed (provides bash, git, and curl).",
        "Dependencies: git, jq (automatically installed via Scoop)"
    ]
}
